{
  "name": "shob",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron-dist/main.js",
  "workspaces": [
    "apps/*",
    "packages/ui",
    "packages/sdk"
  ],
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "dev:vite": "bun run --cwd apps/desktop dev",
    "build": "bun run --cwd packages/server build && bun run --cwd apps/desktop build",
    "build:electron": "bun run build && electron-builder",
    "lint": "eslint .",
    "prepare": "husky",
    "commit": "git-cz",
    "commit:retry": "git-cz --retry",
    "typecheck": "bun run --cwd apps/desktop typecheck"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.6.0",
    "marked": "^18.0.3",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.8.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "remend": "^1.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "commitizen": "^4.3.1",
    "concurrently": "^9.2.1",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "git-cz": "^4.9.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.5"
  }
}
